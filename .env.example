# =========================================================================
# Reliability Analysis - Environment Configuration Example
# Copy this file to '.env' and fill in the values for deployment.
# =========================================================================

# App Settings
LOG_LEVEL=INFO
DEBUG=False

# LLM Vendor-Agnostic Settings
# Supported providers: 'mock', 'gemini', 'openai', 'ollama'
LLM_PROVIDER=mock

# Selected LLM model name. Examples:
# - For 'gemini': 'gemini-1.5-flash' or 'gemini-1.5-pro'
# - For 'openai': 'gpt-4o' or 'gpt-3.5-turbo'
# - For 'ollama': 'llama3', 'mistral', etc.
LLM_MODEL=

# API Credentials (leave empty for providers not in use or for 'mock')
GEMINI_API_KEY=
OPENAI_API_KEY=

# Ollama Endpoint Configuration (only needed if provider is 'ollama')
OLLAMA_BASE_URL=http://localhost:11434
